SECRET_KEY=change-me-to-a-long-random-string
UI_PASSWORD=change-me           # used once to create initial admin user
API_KEY=change-me-to-a-long-random-api-key
APP_URL=https://markd.appfoundry.cc
INITIAL_ADMIN_EMAIL=you@example.com
# Optional: override default sqlite path
# DATABASE_URL=sqlite:////absolute/path/to/markd.db

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=Markd <markd@appfoundry.cc>

# Push notifications — generated automatically by setup.sh
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CONTACT=mailto:your@email.com
